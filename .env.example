# Medium API Token
# 获取方式：Medium Settings → Security → Integration tokens
MEDIUM_TOKEN=your_medium_integration_token_here

# Substack Session Cookie
# 获取方式：登录 Substack → 浏览器 DevTools → Application → Cookies → substack.sid
SUBSTACK_SID=your_substack_sid_cookie_here
# Substack 子域名（你的 newsletter 地址前缀）
SUBSTACK_SUBDOMAIN=your_subdomain_here

# Dev.to API Key
# 获取方式：https://dev.to/settings/extensions → Generate API Key
DEVTO_API_KEY=your_devto_api_key_here

# Hashnode Personal Access Token
# 获取方式：https://hashnode.com/settings/developer → Generate Token
HASHNODE_TOKEN=your_hashnode_token_here
HASHNODE_PUBLICATION_ID=your_publication_id_here
